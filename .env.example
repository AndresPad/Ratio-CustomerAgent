────────────────────────────────────────────────────────────
AZURE_OPENAI_API_VERSION=2024-12-01-preview
# AZURE_OPENAI_ENDPOINT=https://aifoundry-dev-central-us-001.openai.azure.com/
AZURE_OPENAI_ENDPOINT=https://openai-primods-dev-eastus.openai.azure.com/
AZURE_OPENAI_GPT_MODEL_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_GPT_MODEL_NAME=gpt-4o
 
# ─── Key Vault / Cert (client assertion for token exchange) ──────────────────
KEY_VAULT_NAME=kv-ratio-ai-dev
CERT_NAME=ratiodsPEM
 
# ─── MCP Server ──────────────────────────────────────────────────────────────
MCP_SERVER_URL=http://localhost:8000/mcp
MCP_AUTH_AUDIENCE=de5f2e0f-ac6d-418e-a64c-e38dbbd116e5
 
# ─── SSO ─────────────────────────────────────────────────────────────────────
SSO_ENABLED=true
AUTH_TENANT_ID=72f988bf-86f1-41af-91ab-2d7cd011db47
AUTH_CLIENT_ID=8d28fbad-a93e-40f8-a986-1c60b4a8a32e
AUTH_REDIRECT_URI=http://localhost:8501/
AUTH_SCOPES=openid profile offline_access
 
# ─── GroupChat Settings ──────────────────────────────────────────────────────
MAX_ORCHESTRATOR_TURNS=15
 
## ─── Log configuration ──────────────────────────────────────────────────────
ENABLE_AGENT_LOGGING=true
LOG_AGENT_CONTENT=true
ENABLE_LLM_LOGGING=true
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=a90c4a2c-5356-4ec5-9e99-a388a844695b;IngestionEndpoint=https://centralus-2.in.applicationinsights.azure.com/;LiveEndpoint=https://centralus.livediagnostics.monitor.azure.com/;ApplicationId=3e07492e-6d3b-47f3-b7f8-2452a85e0560
 
# ─── Log Analytics Replay (Theatre/Live "Replay" mode) ───────────────────────
# Workspace GUID for log-ratioai-dev — used by server/traces_api.py to
# fetch past investigations by xcv. Requires `az login` locally so that
# DefaultAzureCredential can acquire a token for ade.loganalytics.io.
LOG_ANALYTICS_WORKSPACE_ID=321fc84a-8346-40f4-acf6-a505a7f7dd90
LOG_ANALYTICS_LOOKBACK_DAYS=7
ENABLE_FOUNDRY_TRACING=true
 
# ─── Middleware Settings ─────────────────────────────────────────────────────
ENABLE_AGENT_EVALUATION=false
ENABLE_PROMPT_INJECTION=false
PROMPT_INJECTION_API_URL=http://localhost:9001/injection
PROMPT_INJECTION_API_TIMEOUT=5
EVAL_API_URL=http://localhost:9000/evaluate
EVAL_API_TIMEOUT=10
 
# ─── Middleware Auth (Managed Identity / DefaultAzureCredential) ─────────────
MIDDLEWARE_AUTH_CLIENT_ID=<user-assigned-managed-identity-client-id>
PROMPT_INJECTION_API_SCOPE=api://<app-id>/.default
EVAL_API_SCOPE=api://<app-id>/.default
 