# ─── Azure OpenAI Configuration ─────────────────────────────
AZURE_OPENAI_ENDPOINT=https://your-endpoint.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4.1-mini
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# ─── Azure AI Agent Service ─────────────────────────────────
AZURE_OPENAI_AGENT_ENDPOINT=https://your-endpoint.services.ai.azure.com/api/projects/your-project

# ─── Azure Authentication ───────────────────────────────────
AZURE_TENANT_ID=your-tenant-id
AZURE_SUBSCRIPTION_ID=your-subscription-id

# ─── Application Insights ───────────────────────────────────
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key

# ─── Agent Service Config ───────────────────────────────────
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4.1-mini
AZURE_OPENAI_ADA_DEPLOYMENT=text-embedding-ada-002

# ─── Kusto (Data Analyst Tools) ─────────────────────────────
KUSTO_ICM_CLUSTER_URI=https://your-cluster.kusto.windows.net
KUSTO_ICM_DATABASE=Common

# ─── Log Analytics Replay (Theatre/Live "Replay" mode) ──────
# Workspace GUID used by Code/CustomerAgent/src/server/traces_api.py
# to fetch past investigations by xcv. Requires `az login` locally so
# DefaultAzureCredential can acquire a token for ade.loganalytics.io.
LOG_ANALYTICS_WORKSPACE_ID=your-log-analytics-workspace-guid
LOG_ANALYTICS_LOOKBACK_DAYS=7
ENABLE_FOUNDRY_TRACING=true

# ─── CustomerAgent Publisher / Investigations API ──────────
# Cosmos endpoint + database used by the outcome publisher AND the new
# /api/investigations REST + SSE routes. The publisher already reads
# PUBLISHER_COSMOS_* so we reuse the same names.
PUBLISHER_COSMOS_ENDPOINT=https://cosmos-ratio-ai-dev.documents.azure.com:443/
PUBLISHER_COSMOS_DATABASE=customeragentdb
PUBLISHER_COSMOS_CONTAINER=customer_agent

# Lease container for the Cosmos change-feed processor that powers
# GET /api/investigations/stream. Provisioned alongside customer_agent.
INVESTIGATION_LEASES_CONTAINER=leases

# Log Analytics deep-link builder (v1 of /api/investigations/{xcv}/logs).
# LOG_ANALYTICS_WORKSPACE_ID is already declared above; the next two are
# only needed to build the portal URL.
LOG_ANALYTICS_SUBSCRIPTION_ID=01819f01-7af1-4dd8-9354-9dccc163ceae
LOG_ANALYTICS_RESOURCE_GROUP=rg-ratio-ai-dev

# Service Bus is owned by the publisher/interpreter — the UI does NOT
# consume these topics. Listed here for completeness.
PUBLISHER_SERVICEBUS_FQNS=sbn-ratio-ai-dev.servicebus.windows.net
PUBLISHER_SERVICEBUS_TOPIC=customeragent-outcome
PUBLISHER_SERVICEBUS_INVESTIGATION_TOPIC=customeragent-investigation

# ─── Application Settings ───────────────────────────────────
APP_NAME=MyProject
APP_ENV=development
APP_PORT=8000

# ─── Eval Sidecar ───────────────────────────────────────────
EVAL_SIDECAR_BASE_URL=http://127.0.0.1:8011
