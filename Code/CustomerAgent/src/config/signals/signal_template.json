{
  "signal_types": [
    {
      "id": "SIG-TYPE-1",
      "name": "Service SLI Breach Detected",
      "description": "One or more SLIs have impacted resources with degraded values over a meaningful duration. Aggregated to region-grain: each signal represents the total impact for a customerÃ—regionÃ—SLI combination.",
      "data_source": "SLI breach Kusto query",
      "collection_tools": [
        {
          "tool_name": "collect_impacted_resource_customer_tool",
          "parameters_from_context": {
            "service_tree_id": "service_tree_id",
            "customer_name": "customer_name",
            "start_time": "start_time",
            "end_time": "end_time"
          },
          "feeds_granularities": ["region_slicategory", "cross_region", "multi_sli_region"]
        },
        {
          "tool_name": "collect_vm_impact_tool",
          "parameters_from_context": {
            "service_tree_id": "service_tree_id",
            "customer_name": "customer_name",
            "start_time": "start_time",
            "end_time": "end_time"
          },
          "feeds_granularities": ["region_slicategory", "cross_region", "multi_sli_region"]
        },
        {
          "tool_name": "collect_impacted_resource_multicustomer_tool",
          "parameters_from_context": {
            "service_tree_id": "service_tree_id",
            "start_time": "start_time",
            "end_time": "end_time"
          },
          "feeds_granularities": ["cross_customer_region"]
        }
      ],
      "aggregation": {
        "description": "Raw per-subscription rows are aggregated to region-grain before activation evaluation. sandbox_coder performs this aggregation; signal_builder evaluates rules on the aggregated output.",
        "pre_aggregation_group_by": {
          "region_slicategory": ["CustomerName", "Region", "SliCategory"],
          "cross_region": ["CustomerName", "SliCategory"],
          "multi_sli_region": ["CustomerName", "Region"],
          "cross_customer_region": ["Region", "SliCategory"]
        },
        "computed_metrics": {
          "impacted_subscriptions": "count_distinct(SubscriptionId)",
          "impacted_resources": "sum(ImpactedResources)",
          "total_duration_min": "max(TotalImpactDurationMin)",
          "avg_value": "mean(AvgValueAcrossWindows)",
          "min_value": "min(MinValueAcrossWindows)",
          "earliest_start": "min(EarliestImpactStart)",
          "latest_end": "max(LatestImpactEnd)",
          "severity_tier": "classify_severity(min_value, avg_value)"
        },
        "severity_tiers": {
          "CRITICAL": "min_value == 0 and avg_value < 25.0",
          "HIGH": "min_value == 0 or avg_value < 50.0",
          "WARNING": "avg_value < 75.0",
          "LOW": "avg_value >= 75.0"
        }
      },
      "granularities": [
        {
          "granularity": "region_slicategory",
          "description": "Per-region per-SLI-category impact for the target customer. Aggregates all SLIs of the same category (e.g. Availability, Latency) in a region — how many subscriptions, resources, and distinct SLIs are impacted for this category in this region.",
          "group_by": ["CustomerName", "Region", "SliCategory"],
          "data_fields": ["customer_name", "region", "sli_category", "distinct_sli_count", "sli_list", "impacted_subscriptions", "impacted_resources", "total_duration_min", "avg_value", "min_value", "earliest_start", "latest_end", "severity_tier", "symptoms"],
          "aggregates": {
            "distinct_sli_count": "count_distinct(SLO_SliId)",
            "impacted_subscriptions": "count_distinct(SubscriptionId)",
            "impacted_resources": "sum(ImpactedResources)",
            "total_duration_min": "max(TotalImpactDurationMin)",
            "avg_value": "mean(AvgValueAcrossWindows)",
            "min_value": "min(MinValueAcrossWindows)",
            "sli_list": "collect_distinct(SLO_SliId)",
            "symptoms": "collect_distinct(Symptoms)"
          },
          "confidence": "Medium",
          "rationale": "A region+SLI-category breach is the base signal. Grouping by category (Availability, Latency, etc.) collapses related SLIs into a single signal — multiple SLIs in the same category reinforce each other rather than producing noise.",
          "inputs": ["customer_name", "region", "sli_category", "distinct_sli_count", "sli_list", "impacted_subscriptions", "impacted_resources", "total_duration_min", "avg_value", "min_value", "earliest_start", "latest_end", "severity_tier"],
          "activation": "impacted_resources >= 1",
          "activation_rules": [
            {"impacted_resources_min": 1}
          ],
          "strength_formula": "distinct_sli_count * impacted_subscriptions * impacted_resources * (100 - avg_value) / 100 * log2(1 + total_duration_min / 5)",
          "max_raw_strength": 80.0
        },
        {
          "granularity": "cross_region",
          "description": "Same SLI category breached across multiple regions for the customer. Indicates a widespread platform issue rather than a region-specific problem.",
          "group_by": ["CustomerName", "SliCategory"],
          "data_fields": ["customer_name", "sli_category", "distinct_regions", "distinct_sli_count", "sli_list", "region_list", "total_impacted_subscriptions", "total_impacted_resources", "avg_value", "symptoms"],
          "aggregates": {
            "distinct_regions": "count_distinct(Region)",
            "distinct_sli_count": "count_distinct(SLO_SliId)",
            "total_impacted_subscriptions": "sum(impacted_subscriptions)",
            "total_impacted_resources": "sum(impacted_resources)",
            "avg_value": "mean(avg_value)",
            "sli_list": "collect_distinct(SLO_SliId)",
            "region_list": "collect_distinct(Region)",
            "symptoms": "collect_distinct(symptoms)"
          },
          "confidence": "High",
          "rationale": "The same SLI category breached across multiple distinct regions rules out region-specific causes. The more regions affected, the more likely a global platform or service-level issue.",
          "inputs": ["customer_name", "sli_category", "distinct_regions", "distinct_sli_count", "sli_list", "region_list", "total_impacted_subscriptions", "total_impacted_resources", "avg_value"],
          "activation": "distinct_regions >= 2",
          "activation_rules": [
            {"distinct_regions_min": 2}
          ],
          "strength_formula": "distinct_regions * total_impacted_subscriptions * (100 - avg_value) / 100",
          "max_raw_strength": 60.0
        },
        {
          "granularity": "multi_sli_region",
          "description": "Multiple distinct SLIs breached in the same region for the customer. Indicates a broader systemic issue in that region rather than a single-SLI anomaly.",
          "group_by": ["CustomerName", "Region"],
          "data_fields": ["customer_name", "region", "distinct_sli_count", "sli_list", "total_impacted_subscriptions", "total_impacted_resources", "symptoms"],
          "aggregates": {
            "distinct_sli_count": "count_distinct(SLO_SliId)",
            "total_impacted_subscriptions": "sum(impacted_subscriptions)",
            "total_impacted_resources": "sum(impacted_resources)",
            "sli_list": "collect_distinct(SLO_SliId)",
            "symptoms": "collect_distinct(symptoms)"
          },
          "confidence": "High",
          "rationale": "Multiple SLIs failing in the same region points to regional infrastructure stress, a shared dependency failure, or a broad platform issue — not an isolated SLI flap.",
          "inputs": ["customer_name", "region", "distinct_sli_count", "sli_list", "total_impacted_subscriptions", "total_impacted_resources"],
          "activation": "distinct_sli_count >= 2",
          "activation_rules": [
            {"distinct_sli_count_min": 2}
          ],
          "strength_formula": "distinct_sli_count * total_impacted_subscriptions * total_impacted_resources",
          "max_raw_strength": 80.0
        },
        {
          "granularity": "cross_customer_region",
          "description": "Cross-customer regional degradation — multiple subscriptions (across different customers) impacted for the same SLI category in the same region. Confirms platform-wide issue at the category level.",
          "group_by": ["Region", "SliCategory"],
          "data_fields": ["region", "sli_category", "distinct_sli_count", "distinct_customers", "sli_list", "impacted_subscriptions", "total_impacted_resources", "avg_value", "min_value", "symptoms"],
          "aggregates": {
            "distinct_sli_count": "count_distinct(SLO_SliId)",
            "distinct_customers": "count_distinct(CustomerName)",
            "impacted_subscriptions": "sum(ImpactedSubscriptions)",
            "total_impacted_resources": "sum(ImpactedResources)",
            "avg_value": "mean(AvgValueAcrossWindows)",
            "sli_list": "collect_distinct(SLO_SliId)",
            "symptoms": "collect_distinct(Symptoms)"
          },
          "confidence": "High",
          "rationale": "Multiple subscriptions across different customers breaching the same SLI category in the same region confirms a regional platform issue — not customer-specific or SLI-specific.",
          "inputs": ["region", "sli_category", "distinct_sli_count", "distinct_customers", "sli_list", "impacted_subscriptions", "total_impacted_resources", "avg_value", "min_value"],
          "activation": "impacted_subscriptions >= 3",
          "activation_rules": [
            {"impacted_subscriptions_min": 3}
          ],
          "strength_formula": "distinct_customers * impacted_subscriptions * total_impacted_resources * (100 - avg_value) / 100",
          "max_raw_strength": 150.0
        }
      ]
    },
    {
      "id": "SIG-TYPE-2",
      "name": "Customer Raised Support Request",
      "description": "Customer has raised one or more support cases, indicating they are experiencing issues with Azure services.",
      "data_source": "Support case Kusto query",
      "collection_tools": [
        {
          "tool_name": "collect_support_request_tool",
          "parameters_from_context": {
            "customer_name": "customer_name",
            "start_time": "start_time",
            "end_time": "end_time",
            "support_product_names": "support_product_names"
          },
          "feeds_granularities": ["single_case", "crit_sit", "escalated", "multi_case_same_product"]
        },
        {
          "tool_name": "collect_support_request_multicustomer_tool",
          "parameters_from_context": {
            "start_time": "start_time",
            "end_time": "end_time",
            "support_product_names": "support_product_names"
          },
          "feeds_granularities": ["multi_customer_same_product", "multi_customer_crit_sit"]
        }
      ],
      "granularities": [
        {
          "granularity": "single_case",
          "group_by": ["CaseNumber"],
          "data_fields": ["CaseNumber", "Title", "State", "IsCritSit", "SupportProductName", "Region", "CreatedDateTime", "IsEscalated", "InitialSeverity", "Severity", "AzureSubscriptionId", "Customer_CloudCustomerName"],
          "confidence": "Medium",
          "rationale": "A single support case is a meaningful signal but could be routine. Confidence increases with severity and CritSit/escalation flags.",
          "inputs": ["case_number", "title", "state", "is_crit_sit", "support_product_name", "region", "created_date_time", "is_escalated", "initial_severity", "severity", "azure_subscription_id", "customer_name"],
          "activation": "case exists",
          "activation_rules": [
            {"case_number_present": true}
          ],
          "strength_formula": "(severity == 'A' ? 3 : severity == 'B' ? 2 : 1) * (is_crit_sit ? 3 : 1)",
          "max_raw_strength": 9.0
        },
        {
          "granularity": "crit_sit",
          "group_by": ["CaseNumber"],
          "data_fields": ["CaseNumber", "Title", "State", "IsCritSit", "SupportProductName", "Region", "CreatedDateTime", "Severity", "AzureSubscriptionId", "Customer_CloudCustomerName"],
          "confidence": "High",
          "rationale": "A CritSit flag means the customer or support engineer has declared a critical situation — this is a high-urgency signal that demands immediate attention.",
          "inputs": ["case_number", "title", "state", "support_product_name", "region", "created_date_time", "severity", "azure_subscription_id", "customer_name"],
          "activation": "is_crit_sit == True",
          "activation_rules": [
            {"is_crit_sit": true}
          ],
          "strength_formula": "(severity == 'A' ? 3 : 2) * 3",
          "max_raw_strength": 9.0
        },
        {
          "granularity": "escalated",
          "group_by": ["CaseNumber"],
          "data_fields": ["CaseNumber", "Title", "State", "SupportProductName", "Region", "CreatedDateTime", "IsEscalated", "InitialSeverity", "Severity", "AzureSubscriptionId", "Customer_CloudCustomerName"],
          "confidence": "High",
          "rationale": "An escalated case or one where severity increased post-filing indicates the issue is more serious than initially assessed. This strengthens the signal.",
          "inputs": ["case_number", "title", "state", "support_product_name", "region", "created_date_time", "is_escalated", "initial_severity", "severity", "azure_subscription_id", "customer_name"],
          "activation": "is_escalated == True or severity > initial_severity",
          "activation_rules": [
            {"is_escalated_or_severity_increased": true}
          ],
          "strength_formula": "(severity == 'A' ? 3 : severity == 'B' ? 2 : 1) * 2",
          "max_raw_strength": 6.0
        },
        {
          "granularity": "multi_case_same_product",
          "group_by": ["SupportProductName"],
          "data_fields": ["SupportProductName", "support_product_name", "case_count", "max_severity"],
          "aggregates": {
            "case_count": "count(CaseNumber)",
            "max_severity": "min(Severity)"
          },
          "confidence": "High",
          "rationale": "Multiple support cases for the same SupportProductName from the same customer suggests a systemic product issue rather than an isolated incident.",
          "inputs": ["case_number", "title", "support_product_name", "created_date_time", "severity", "azure_subscription_id", "customer_name"],
          "activation": "distinct_cases_same_product >= 2",
          "activation_rules": [
            {"case_count_min": 2}
          ],
          "strength_formula": "case_count * (max_severity == 'A' ? 3 : max_severity == 'B' ? 2 : 1)",
          "max_raw_strength": 15.0
        },
        {
          "granularity": "multi_customer_same_product",
          "group_by": ["SupportProductName"],
          "data_fields": ["SupportProductName", "TotalCaseCount", "DistinctCustomerCount", "DistinctCritSitCustomerCount", "MaxSeverity", "CritSitCount", "CustomerList", "CritSitCustomerList", "RegionList", "CritSitRegionList", "CaseNumbers", "CritSitCaseNumbers", "EarliestCase", "LatestCase"],
          "aggregates": {
            "customer_count": "pre_aggregated:DistinctCustomerCount",
            "total_case_count": "pre_aggregated:TotalCaseCount",
            "max_severity": "pre_aggregated:MaxSeverity"
          },
          "confidence": "High",
          "rationale": "Multiple distinct customers filing support cases for the same product indicates a platform-wide service issue rather than a customer-specific problem.",
          "inputs": ["support_product_name", "total_case_count", "distinct_customer_count", "distinct_crit_sit_customer_count", "max_severity", "crit_sit_count", "customer_list", "crit_sit_customer_list", "region_list", "crit_sit_region_list", "case_numbers", "crit_sit_case_numbers", "earliest_case", "latest_case"],
          "activation": "distinct_customers_same_product >= 2",
          "activation_rules": [
            {"customer_count_min": 2}
          ],
          "strength_formula": "customer_count * total_case_count * (max_severity == 'A' ? 3 : max_severity == 'B' ? 2 : 1)",
          "max_raw_strength": 40.0
        },
        {
          "granularity": "multi_customer_crit_sit",
          "group_by": ["SupportProductName"],
          "data_fields": ["SupportProductName", "DistinctCritSitCustomerCount", "CritSitCount", "CritSitCustomerList", "CritSitRegionList", "CritSitCaseNumbers", "EarliestCase", "LatestCase"],
          "aggregates": {
            "distinct_crit_sit_customer_count": "pre_aggregated:DistinctCritSitCustomerCount",
            "crit_sit_count": "pre_aggregated:CritSitCount"
          },
          "confidence": "Highest",
          "rationale": "Multiple distinct customers raising CritSit for the same product is the strongest possible support signal — a smoking-gun indicator of critical platform failure requiring immediate coordinated response.",
          "inputs": ["support_product_name", "distinct_crit_sit_customer_count", "crit_sit_count", "crit_sit_customer_list", "crit_sit_region_list", "crit_sit_case_numbers", "earliest_case", "latest_case"],
          "activation": "is_crit_sit == true and distinct_crit_sit_customers >= 2",
          "activation_rules": [
            {"is_crit_sit": true},
            {"distinct_crit_sit_customer_count_min": 2}
          ],
          "strength_formula": "distinct_crit_sit_customer_count * crit_sit_count * 3",
          "max_raw_strength": 60.0
        }
      ]
    },
    {
      "id": "SIG-TYPE-3",
      "name": "Service Team Creates Incident",
      "description": "Service team has created an incident as a response to internal detection or external reports.",
      "data_source": "Incident Kusto query",
      "collection_tools": [
        {
          "tool_name": "collect_incident_details_tool",
          "parameters_from_context": {
            "start_time": "start_time",
            "end_time": "end_time",
            "owning_tenant_names": "owning_tenant_names"
          },
          "feeds_granularities": ["one_or_more_incident", "outage_confirmed", "with_child_incidents", "customer_correlated", "multi_incident"]
        }
      ],
      "granularities": [
        {
          "granularity": "one_or_more_incident",
          "group_by": ["OwningTenantName"],
          "data_fields": ["OwningTenantName", "owning_tenant_name", "incident_count", "max_severity", "outage_count", "incident_ids", "earliest_impact_date"],
          "aggregates": {
            "incident_count": "count(IncidentId)",
            "max_severity": "min(Severity)",
            "outage_count": "count_where(IsOutage == true)",
            "incident_ids": "collect(IncidentId)",
            "earliest_impact_date": "min(ImpactStartDate)"
          },
          "confidence": "Medium",
          "rationale": "One or more incidents from a service team is a meaningful signal but many incidents are exploratory or low-impact. Confidence increases with count, severity, and outage confirmation.",
          "inputs": ["owning_tenant_name", "incident_count", "incident_ids", "max_severity", "outage_count", "earliest_impact_date"],
          "activation": "incident_count >= 1",
          "activation_rules": [
            {"incident_count_min": 1}
          ],
          "strength_formula": "incident_count * (4 - max_severity) * (outage_count > 0 ? 2 : 1)",
          "max_raw_strength": 12.0
        },
        {
          "granularity": "outage_confirmed",
          "group_by": ["IncidentId"],
          "data_fields": ["IncidentId", "Severity", "IsOutage", "Status", "Title", "CreateDate", "ImpactStartDate", "ChildCount", "SupportTicketId", "OwningTenantName"],
          "confidence": "High",
          "rationale": "When IsOutage is true, the service team has explicitly confirmed customer-facing impact. This is one of the strongest signals available.",
          "inputs": ["incident_id", "severity", "is_outage", "status", "title", "impact_start_date", "owning_tenant_name"],
          "activation": "is_outage == true",
          "activation_rules": [
            {"is_outage": true}
          ],
          "strength_formula": "(4 - severity) * 2",
          "max_raw_strength": 6.0
        },
        {
          "granularity": "with_child_incidents",
          "group_by": ["IncidentId"],
          "data_fields": ["IncidentId", "Severity", "IsOutage", "Status", "Title", "CreateDate", "ImpactStartDate", "ChildCount", "OwningTenantName"],
          "confidence": "High",
          "rationale": "Confirmed outage (IsOutage=true) with multiple child incidents indicates widespread verified impact across teams or regions. The more children, the broader the blast radius.",
          "inputs": ["incident_id", "severity", "is_outage", "status", "title", "child_count", "owning_tenant_name"],
          "activation": "is_outage == true and child_count >= 3",
          "activation_rules": [
            {"is_outage": true},
            {"child_count_min": 3}
          ],
          "strength_formula": "child_count * (4 - severity) * 2",
          "max_raw_strength": 50.0
        },
        {
          "granularity": "customer_correlated",
          "group_by": ["IncidentId"],
          "data_fields": ["IncidentId", "Severity", "IsOutage", "Status", "Title", "CreateDate", "ImpactStartDate", "SupportTicketId", "OwningTenantName"],
          "confidence": "High",
          "rationale": "Confirmed outage (IsOutage=true) linked to a customer's SupportTicketId — direct correlation between a verified platform outage and a customer complaint.",
          "inputs": ["incident_id", "severity", "is_outage", "status", "title", "support_ticket_id", "owning_tenant_name"],
          "activation": "is_outage == true and support_ticket_id is not empty",
          "activation_rules": [
            {"is_outage": true},
            {"support_ticket_id_present": true}
          ],
          "strength_formula": "(4 - severity) * 3",
          "max_raw_strength": 9.0
        },
        {
          "granularity": "multi_incident",
          "group_by": ["OwningTenantName"],
          "data_fields": ["OwningTenantName", "owning_tenant_name", "incident_count", "max_severity", "outage_count", "incident_ids", "earliest_impact_date"],
          "aggregates": {
            "incident_count": "count(IncidentId)",
            "max_severity": "min(Severity)",
            "outage_count": "count_where(IsOutage == true)",
            "incident_ids": "collect(IncidentId)",
            "earliest_impact_date": "min(ImpactStartDate)"
          },
          "confidence": "High",
          "rationale": "Multiple confirmed outages (IsOutage=true) from the same tenant indicate a systemic verified failure pattern — not an isolated incident but a recurring or compound failure.",
          "inputs": ["owning_tenant_name", "incident_count", "incident_ids", "max_severity", "outage_count", "earliest_impact_date"],
          "activation": "outage_count >= 1 and incident_count >= 2",
          "activation_rules": [
            {"outage_count_min": 1},
            {"incident_count_min": 2}
          ],
          "strength_formula": "incident_count * (4 - max_severity) * 2",
          "max_raw_strength": 24.0
        }
      ]
    },
    {
      "id": "SIG-TYPE-4",
      "name": "Dependency Service Degradation",
      "description": "Dependency services that the primary customer service relies on show SLI breaches in regions where the customer has resources. Aggregated to region-grain per dependency service.",
      "data_source": "SLI breach Kusto query (multi-customer) per dependency service, filtered to customer regions",
      "collection_strategy": "dependency_scan",
      "dependency_mappings": "dependency_mappings.json",
      "region_tool": {
        "tool_name": "collect_customer_region_tool",
        "parameters_from_context": {
          "service_tree_id": "service_tree_id",
          "customer_name": "customer_name",
          "start_time": "start_time",
          "end_time": "end_time"
        }
      },
      "dependency_tool": {
        "tool_name": "collect_impacted_resource_multicustomer_tool",
        "parameter_field": "service_tree_id",
        "extra_params_from_context": {
          "start_time": "start_time",
          "end_time": "end_time"
        }
      },
      "granularities": [
        {
          "granularity": "dep_region_sli",
          "description": "Single dependency SLI breach in a customer region. Base dependency signal.",
          "group_by": ["DependencyServiceName", "Region", "SLO_SliId"],
          "data_fields": ["DependencyServiceName", "DependencyCategory", "Region", "SLO_SliId", "SliCategory", "Symptoms", "ImpactedResources", "ImpactedSubscriptions", "TotalImpactDurationMin", "EarliestImpactStart", "LatestImpactEnd", "AvgValueAcrossWindows", "MinValueAcrossWindows"],
          "confidence": "Medium",
          "rationale": "A single dependency service SLI breach in a customer region is a leading indicator of potential spill-over. Confidence increases with impact breadth.",
          "inputs": ["dependency_service_name", "dependency_category", "region", "slo_sli_id", "impacted_resources", "impacted_subscriptions", "total_impact_duration_min", "avg_value_across_windows", "min_value_across_windows"],
          "activation": "impacted_resources >= 10",
          "activation_rules": [
            {"impacted_resources_min": 10}
          ],
          "strength_formula": "impacted_resources * (100 - avg_value_across_windows) / 100",
          "max_raw_strength": 40.0
        },
        {
          "granularity": "dep_multi_sli_region",
          "description": "Multiple SLIs breached for the same dependency service in a customer region — broad service-level degradation.",
          "group_by": ["DependencyServiceName", "Region"],
          "data_fields": ["DependencyServiceName", "dependency_service_name", "Region", "region", "distinct_sli_count", "total_impacted_resources", "total_impacted_subscriptions", "avg_value_across_windows", "symptoms"],
          "aggregates": {
            "distinct_sli_count": "count_distinct(SLO_SliId)",
            "total_impacted_resources": "sum(ImpactedResources)",
            "total_impacted_subscriptions": "sum(ImpactedSubscriptions)",
            "avg_value_across_windows": "avg(AvgValueAcrossWindows)",
            "symptoms": "collect_distinct(Symptoms)"
          },
          "confidence": "High",
          "rationale": "Multiple SLIs breached for the same dependency service in a customer region indicates broad service-level degradation, not a single-SLI anomaly.",
          "inputs": ["dependency_service_name", "dependency_category", "region", "slo_sli_id", "impacted_resources", "impacted_subscriptions", "total_impact_duration_min", "avg_value_across_windows"],
          "activation": "distinct_sli_count >= 2",
          "activation_rules": [
            {"distinct_sli_count_min": 2}
          ],
