{
  "agents": [
    {
      "name": "orchestrator",
      "description": "Routes user queries to appropriate specialist agents and decides turn order",
      "prompt_file": "maf_orchestrator_prompt.txt",
      "model": "gpt-4o",
      "temperature": 1.0,
      "tool_mode": "none",
      "mcp_tools": [],
      "evaluate": false,
      "prompt_injection": true,
      "log_input": true,
      "log_output": true
    },
    {
      "name": "entity_extractor",
      "description": "Extracts and normalizes entities (offerings, regions, services, customers) from the user query using synonym lookup",
      "prompt_file": "maf_entity_extractor_prompt.txt",
      "model": "gpt-4o",
      "temperature": 1.0,
      "tool_mode": "filtered",
      "mcp_tools": [
        "normalize_entity_mapping_tool"
      ],
      "evaluate": false,
      "prompt_injection": true,
      "log_input": true,
      "log_output": true
    },
    {
      "name": "outage_analyst",
      "description": "Generates and executes T-SQL for outage/incident analysis: severity, TTM, QCO, CritSit distributions, RCA",
      "prompt_file": "maf_outage_analyst_prompt.txt",
      "knowledge": [
        "sql_standards.md"
      ],
      "model": "gpt-4o",
      "temperature": 1.0,
      "tool_mode": "filtered",
      "mcp_tools": [
        "run_tsql_query_tool",
        "collect_root_cause_tool"
      ],
      "evaluate": true,
      "prompt_injection": true,
      "log_input": true,
      "log_output": true
    },
    {
      "name": "airo_analyst",
      "description": "Generates and executes T-SQL for AIRO/AIROD impact metrics at fleet, region, and customer granularity",
      "prompt_file": "maf_airo_analyst_prompt.txt",
      "knowledge": [
        "sql_standards.md"
      ],
      "model": "gpt-4o",
      "temperature": 1.0,
      "tool_mode": "filtered",
      "mcp_tools": [
        "run_tsql_query_tool"
      ],
      "evaluate": true,
      "prompt_injection": true,
      "log_input": true,
      "log_output": true
    },
    {
      "name": "customer_insights",
      "description": "Customer impact analysis: CritSits per customer, AIRO by customer, QEI/QEIS lists, communication gaps",
      "prompt_file": "maf_customer_insights_prompt.txt",
      "knowledge": [
        "sql_standards.md"
      ],
      "model": "gpt-4o",
      "temperature": 1.0,
      "tool_mode": "filtered",
      "mcp_tools": [
        "run_tsql_query_tool"
      ],
      "evaluate": true,
      "prompt_injection": true,
      "log_input": true,
      "log_output": true
    },
    {
      "name": "visualizer",
      "description": "Generates ready-to-run Streamlit visualization code from analytical datasets produced by other agents",
      "prompt_file": "maf_visualizer_prompt.txt",
      "model": "gpt-4o",
      "temperature": 1.0,
      "tool_mode": "none",
      "mcp_tools": [],
      "evaluate": false,
      "prompt_injection": true,
      "log_input": true,
      "log_output": true
    },
    {
      "name": "summarizer",
      "description": "Consolidates all analysis results into a final structured response with headline, summary bullets, and datasets",
      "prompt_file": "maf_summarizer_prompt.txt",
      "model": "gpt-4o",
      "temperature": 1.0,
      "tool_mode": "none",
      "mcp_tools": [],
      "evaluate": true,
      "log_input": true,
      "log_output": true,
      "prompt_injection": true
    },
    {
      "name": "analyst_coordinator",
      "description": "Invokes outage_analyst, airo_analyst, and customer_insights agents in parallel when the user explicitly requests all analysts to run concurrently",
      "prompt_file": "maf_analyst_coordinator_prompt.txt",
      "model": "gpt-4o",
      "temperature": 1.0,
      "tool_mode": "agent_tools",
      "mcp_tools": [],
      "sub_agents": [
        "outage_analyst",
        "airo_analyst",
        "customer_insights"
      ],
      "evaluate": false,
      "prompt_injection": true,
      "log_input": true,
      "log_output": true
    },
    {
      "name": "investigation_orchestrator",
      "description": "Routes investigation turns through phases: triage \u00e2\u2020\u2019 hypothesizing \u00e2\u2020\u2019 planning \u00e2\u2020\u2019 collecting \u00e2\u2020\u2019 reasoning \u00e2\u2020\u2019 acting \u00e2\u2020\u2019 notifying. Reads parsed signals and decides the next agent.",
      "prompt_file": "investigation_orchestrator_prompt.txt",
      "model": "gpt-4o",
      "temperature": 0.3,
      "tool_mode": "none",
      "mcp_tools": [],
      "evaluate": false,
      "prompt_injection": true,
      "log_input": true,
      "log_output": true
    },
    {
      "name": "triage_agent",
      "description": "Classifies activated signals, extracts symptoms from config templates, and determines investigation category (CAT-HEALTH-DEGRADE, CAT-OUTAGE-IMPACT, CAT-PROACTIVE-RISK, CAT-SUPPORT-ESCALATION)",
      "prompt_file": "investigation_triage_prompt.txt",
      "model": "gpt-4o",
      "temperature": 0.3,
      "max_completion_tokens": 16000,
      "tool_mode": "filtered",
      "evaluate": false,
      "prompt_injection": true,
      "log_input": true,
      "log_output": true
    },
    {
      "name": "data_fetcher",
      "description": "Fetches raw data from MCP collection tools and deposits full datasets into sandbox /mnt/data/ for downstream analysis. Does NOT summarize or interpret data.",
      "prompt_file": "investigation_data_fetcher_prompt.txt",
      "model": "gpt-4o",
      "temperature": 0.3,
      "tool_mode": "fetch_tools",
      "mcp_tools": [],
      "evaluate": false,
      "prompt_injection": true,
      "log_input": true,
      "log_output": true
    },
    {
      "name": "evidence_planner",
      "description": "Plans and executes evidence collection for the current hypothesis by dispatching data_fetcher to populate sandbox, then sandbox_coder to analyze the raw datasets",
      "prompt_file": "investigation_evidence_planner_prompt.txt",
      "model": "gpt-4o",
      "temperature": 0.5,
      "max_completion_tokens": 8000,
      "tool_mode": "agent_tools",
      "mcp_tools": [],
      "sub_agents": [
        "data_fetcher",
        "sandbox_coder"
      ],
      "evaluate": false,
      "prompt_injection": true,
      "log_input": true,
      "log_output": true
    },
    {
      "name": "reasoner",
      "description": "Evaluates collected evidence against the current hypothesis to determine CONFIRMED, CONTRIBUTING, REFUTED, or needs_more_evidence. Pure reasoning \u00e2\u20ac\u201d no tools.",
      "prompt_file": "investigation_reasoner_prompt.txt",
      "model": "gpt-4o",
      "temperature": 0.3,
      "max_completion_tokens": 8000,
      "tool_mode": "none",
      "mcp_tools": [],
      "evaluate": false,
      "prompt_injection": true,
      "log_input": true,
      "log_output": true
    },
    {
      "name": "narrator",
      "description": "Observes investigation agent outputs and produces first-person human-readable narration of the investigation flow. Runs outside the GroupChat after each agent turn.",
      "prompt_file": "investigation_narrator_prompt.txt",
      "model": "gpt-4o",
      "temperature": 0.7,
      "tool_mode": "none",
      "mcp_tools": [],
      "evaluate": false,
      "prompt_injection": true,
      "log_input": true,
      "log_output": true
    },
    {
      "name": "action_planner",
      "description": "Selects and prioritizes remediation actions from the action catalog for confirmed or contributing hypotheses. Pure reasoning \u00e2\u20ac\u201d no tools, no execution.",
      "prompt_file": "investigation_action_planner_prompt.txt",
      "model": "gpt-4o",
      "temperature": 0.3,
      "tool_mode": "none",
      "mcp_tools": [],
      "evaluate": false,
      "prompt_injection": true,
      "log_input": true,
      "log_output": true
    },
    {
      "name": "sandbox_coder",
      "description": "Authors and executes Python analysis code in a secure sandbox. Given a question and collected evidence data, writes a statistical analysis script, executes it, and returns computed results (stdout answer + CSV files + manifest).",
      "prompt_file": "investigation_sandbox_coder_prompt.txt",
      "model": "gpt-4o",
      "temperature": 0.3,
      "tool_mode": "sandbox",
      "mcp_tools": [],
      "evaluate": false,
      "prompt_injection": true,
      "log_input": true,
      "log_output": true
    }
  ],
  "workflow": {
    "type": "group_chat",
    "orchestrator_agent": "orchestrator",
    "participants": [
      "entity_extractor",
      "outage_analyst",
      "airo_analyst",
      "customer_insights",
      "analyst_coordinator",
      "visualizer",
      "summarizer",
      "sandbox_coder"
    ],
    "max_turns": 15,
    "intermediate_outputs": true,
    "termination_keyword": "WORKFLOW_COMPLETE"
  },
  "investigation_workflow": {
    "type": "group_chat",
    "use_speaker_selector": true,
    "orchestrator_agent": "investigation_orchestrator",
    "participants": [
      "evidence_planner",
      "reasoner"
    ],
    "action_agent": "action_planner",
    "max_turns": 40,
    "max_evidence_cycles": 2,
    "intermediate_outputs": true,
    "termination_signal": "investigation_resolved",
    "narrator_enabled": true,
    "agent_timeout_seconds": {
      "triage_agent": 120,
      "action_planner": 120,
      "group_chat": 600,
      "default": 120
    },
    "retry_policy": {
      "triage_agent": {
        "max_retries": 2,
        "backoff": "linear",
        "backoff_base_seconds": 1
      },
      "evidence_planner": {
        "max_retries": 1,
        "backoff": "none",
        "backoff_base_seconds": 0
      },
      "reasoner": {
        "max_retries": 1,
        "backoff": "none",
        "backoff_base_seconds": 0
      },
      "action_planner": {
        "max_retries": 1,
        "backoff": "linear",
        "backoff_base_seconds": 1
      },
      "default": {
        "max_retries": 0,
        "backoff": "none",
        "backoff_base_seconds": 0
      }
    },
    "phase_transitions": {
      "hypothesizing": "evidence_planner",
      "planning": "investigation_orchestrator",
      "collecting": "reasoner",
      "reasoning": "investigation_orchestrator",
      "notifying": "investigation_orchestrator"
    },
    "agent_roles": {
      "orchestrator": "investigation_orchestrator",
      "evidence_planner": "evidence_planner",
      "reasoner": "reasoner",
      "triage": "triage_agent",
      "action_planner": "action_planner",
      "narrator": "narrator"
    },
    "cycle_detection": {
      "history_window": 6,
      "max_repeated_pattern": 3,
      "max_identical_messages": 2
    },
    "max_eval_hypotheses": 4,
    "max_rows_per_grain": 5,
    "phase_pipeline": {
      "phases": [
        {
          "name": "triage",
          "agent": "triage_agent",
          "mode": "standalone",
          "retryable": true
        },
        {
          "name": "hypothesizing",
          "mode": "programmatic"
        },
        {
          "name": "evidence_loop",
          "agents": ["evidence_planner", "reasoner"],
          "mode": "groupchat",
          "max_cycles": 2,
          "sub_phases": ["planning", "collecting", "reasoning"]
        },
        {
          "name": "acting",
          "agent": "action_planner",
          "mode": "standalone",
          "retryable": true
        },
        {
          "name": "notifying",
          "mode": "auto_complete"
        }
      ],
      "legal_transitions": {}
    }
  }
}
