{
  "output_base": "/mnt/data/{xcv}",
  "subdirs": {
    "evidence": "evidence",
    "analysis": "analysis"
  },
  "fetch_tools": {
    "fetch_sli_data": {
      "er_patterns": ["ER-SLI-*", "ER-LOAD-*"],
      "mcp_calls": [
        {
          "tool": "collect_impacted_resource_customer_tool",
          "output_file": "sli_customer.json",
          "params": ["service_tree_id", "customer_name", "start_time", "end_time"]
        },
        {
          "tool": "collect_impacted_resource_multicustomer_tool",
          "output_file": "sli_multicustomer.json",
          "params": ["service_tree_id", "start_time", "end_time"]
        }
      ]
    },
    "fetch_incident_data": {
      "er_patterns": ["ER-OUT-*"],
      "mcp_calls": [
        {
          "tool": "collect_incident_details_tool",
          "output_file": "incidents.json",
          "params": ["start_time", "end_time", "owning_tenant_names?"]
        }
      ]
    },
    "fetch_support_data": {
      "er_patterns": ["ER-TKT-*"],
      "mcp_calls": [
        {
          "tool": "collect_support_request_tool",
          "output_file": "support_customer.json",
          "params": ["customer_name", "start_time", "end_time", "support_product_names?"]
        },
        {
          "tool": "collect_support_request_multicustomer_tool",
          "output_file": "support_multicustomer.json",
          "params": ["start_time", "end_time", "support_product_names?"]
        }
      ]
    }
  }
}
