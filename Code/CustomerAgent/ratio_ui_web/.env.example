# ─── ratio_ui_web — local dev (Vite) ─────────────────────────
# Copy to .env.local (gitignored) and tweak as needed.

# Enable the Server-Sent-Events live stream backed by Cosmos change feed.
# When "false", the UI falls back to short polling (5s) of
# /api/investigations/active so we can disable SSE without redeploying.
VITE_ENABLE_INVESTIGATION_STREAM=true

# Pure-frontend mode: when "true", investigationsClient returns canned
# data from src/fixtures/mockInvestigations.ts so you can iterate on UI
# without the backend or Cosmos access.
VITE_USE_FIXTURES=false
