server {
    listen 80;
    server_name _;
    root /usr/share/nginx/html;
    index index.html;

    # SPA fallback — serve index.html for all non-file routes
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Proxy API requests to the main agents backend
    location /api/ {
        proxy_pass ${BACKEND_AGENTS_URL};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
        proxy_connect_timeout 10s;
    }

    # Proxy SR Insights API requests
    location /sr-api/ {
        rewrite ^/sr-api/(.*) /$1 break;
        proxy_pass ${BACKEND_SR_INSIGHTS_URL};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
        proxy_connect_timeout 10s;
    }

    # Proxy Fuse API requests
    location /fuse-api/ {
        rewrite ^/fuse-api/(.*) /$1 break;
        proxy_pass ${BACKEND_FUSE_URL};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300s;
        proxy_connect_timeout 10s;
    }

    # ── CustomerAgent backend (port 8503 locally / ca-ratio-customeragent-dev in Azure) ──
    #
    # The SSE stream MUST be matched before the catch-all /customer-agent-api/
    # location so its no-buffering settings take effect. Nginx picks the most
    # specific prefix match.
    location /customer-agent-api/api/investigations/stream {
        rewrite ^/customer-agent-api/(.*) /$1 break;
        proxy_pass ${BACKEND_CUSTOMERAGENT_URL};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        # Pass through Entra Easy Auth headers when fronted by Container Apps.
        proxy_set_header Authorization $http_authorization;
        proxy_set_header X-MS-CLIENT-PRINCIPAL $http_x_ms_client_principal;
        proxy_set_header X-MS-CLIENT-PRINCIPAL-ID $http_x_ms_client_principal_id;
        proxy_set_header X-MS-CLIENT-PRINCIPAL-NAME $http_x_ms_client_principal_name;

        # SSE-specific: disable any buffering / coalescing that would batch
        # event frames until the connection closes.
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_buffering off;
        proxy_cache off;
        gzip off;
        chunked_transfer_encoding off;

        # Long-lived connections — the backend sends a heartbeat every 15s
        # but we don't want the proxy to drop quiet streams either.
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        proxy_connect_timeout 10s;
    }

    location /customer-agent-api/ {
        rewrite ^/customer-agent-api/(.*) /$1 break;
        proxy_pass ${BACKEND_CUSTOMERAGENT_URL};
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Authorization $http_authorization;
        proxy_set_header X-MS-CLIENT-PRINCIPAL $http_x_ms_client_principal;
        proxy_set_header X-MS-CLIENT-PRINCIPAL-ID $http_x_ms_client_principal_id;
        proxy_set_header X-MS-CLIENT-PRINCIPAL-NAME $http_x_ms_client_principal_name;
        proxy_read_timeout 300s;
        proxy_connect_timeout 10s;
    }

    # Cache static assets
    location ~* \.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;
}
